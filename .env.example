# ═══════════════════════════════════════════════════════════════════════════════
# AI Resume Coach — Environment Configuration
# Copy to .env and fill in the values for your chosen LLM provider.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider (choose ONE) ─────────────────────────────────────────────────
#
#   ollama     → FREE. Local dev. No internet needed.
#                Install: https://ollama.ai
#                Then run: ollama pull mistral
#
#   replicate  → FREE tier. Cloud API. Best for Week 1 prompt experimentation.
#                Sign up: https://replicate.com → Account → API Tokens
#
#   sagemaker  → Self-hosted Mistral-7B on AWS. REQUIRED for graded submission.
#                Deploy: python scripts/deploy_sagemaker.py --model mistral
#                Cost: ~$1.52/hr — delete endpoint after grading!
#
#   bedrock    → AWS Bedrock (Claude Sonnet). Fallback if SageMaker credits run out.
#
#   openai     → OpenAI GPT-4o. Quick fallback for testing.
#
LLM_PROVIDER=ollama

# ── Embeddings Provider (for FAISS vector store) ──────────────────────────────
# ollama | bedrock | openai
EMBEDDING_PROVIDER=ollama

# ══════════════════════════════════════════════════════════════════════════════
# PROVIDER SETTINGS — fill in only the section matching your LLM_PROVIDER
# ══════════════════════════════════════════════════════════════════════════════

# ── OLLAMA settings ───────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── REPLICATE settings ────────────────────────────────────────────────────────
REPLICATE_API_TOKEN=r8_YOUR_TOKEN_HERE
REPLICATE_MODEL=mistralai/mistral-7b-instruct-v0.2
REPLICATE_MODEL_VERSION=

# ── SAGEMAKER settings ────────────────────────────────────────────────────────
SAGEMAKER_ENDPOINT_NAME=resume-coach-mistral-7b
SAGEMAKER_REGION=us-east-1

# ── BEDROCK settings ──────────────────────────────────────────────────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── OPENAI settings ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
OPENAI_MODEL_ID=gpt-4o

# ── AWS Credentials (needed for SageMaker and Bedrock) ───────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
S3_BUCKET=your-resume-coach-bucket-name

# ── Langfuse Observability ────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-YOUR_PUBLIC_KEY_HERE
LANGFUSE_SECRET_KEY=sk-lf-YOUR_SECRET_KEY_HERE
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true

# ── API Security ──────────────────────────────────────────────────────────────
API_KEY=dev-key-change-in-production
DEBUG=false

# ── Classical ML ─────────────────────────────────────────────────────────────
ML_ENABLED=true
